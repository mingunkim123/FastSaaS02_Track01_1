---
import StoreBadge from './StoreBadge.astro';
import WaitlistForm from './WaitlistForm.tsx';
import { waitlistCopy, downloadCopy } from '../content';
---

<section id="waitlist" class="relative overflow-hidden bg-neutral py-24 sm:py-28">
  <!-- 배경 그라데이션 글로우 -->
  <div class="absolute inset-0 -z-10 opacity-40" aria-hidden="true">
    <div class="absolute -top-40 left-1/2 h-96 w-96 -translate-x-1/2 rounded-full bg-primary/40 blur-3xl"></div>
    <div class="absolute bottom-0 right-0 h-72 w-72 rounded-full bg-secondary/20 blur-3xl"></div>
  </div>

  <div class="mx-auto max-w-4xl px-6 text-center">
    <span class="inline-flex items-center gap-2 rounded-full border border-neutral-content/20 bg-neutral-content/5 px-3.5 py-1.5 text-xs font-semibold text-neutral-content/80">
      <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-secondary"></span>
      출시 준비 중
    </span>

    <h2 class="mt-6 text-3xl font-extrabold tracking-tight text-neutral-content sm:text-4xl lg:text-5xl">
      {waitlistCopy.heading}
    </h2>
    <p class="mt-4 text-lg text-neutral-content/70">
      {waitlistCopy.sub}
    </p>

    <div class="mt-10">
      <WaitlistForm client:load />
    </div>

    <div class="mt-16 pt-10 border-t border-neutral-content/10">
      <p class="text-sm font-medium text-neutral-content/60">또는 앱 출시를 기다려주세요</p>
      <div class="mt-5 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <StoreBadge platform="android" disabled />
        <StoreBadge platform="ios" disabled />
      </div>
      <p class="mt-5 text-xs text-neutral-content/50">{downloadCopy.note}</p>
    </div>
  </div>
</section>
